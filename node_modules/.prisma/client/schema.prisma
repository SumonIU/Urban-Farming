generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  VENDOR
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

enum CertificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AvailabilityStatus {
  AVAILABLE
  RESERVED
  UNAVAILABLE
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}

enum PlantHealthStatus {
  GOOD
  WATCH
  CRITICAL
}

enum PostStatus {
  PUBLISHED
  FLAGGED
  ARCHIVED
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String
  role      UserRole
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  vendorProfile  VendorProfile?
  orders         Order[]
  rentalBookings RentalBooking[]
  posts          CommunityPost[]
  plantTracks    Plant[]
}

model VendorProfile {
  id                  String              @id @default(cuid())
  userId              String              @unique
  farmName            String
  certificationStatus CertificationStatus @default(PENDING)
  farmLocation        String
  isApproved          Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  produce             Produce[]
  rentalSpaces        RentalSpace[]
  sustainabilityCerts SustainabilityCert[]
  orders              Order[]
  plantTracks         Plant[]
}

model Produce {
  id                  String              @id @default(cuid())
  vendorId            String
  name                String
  description         String
  price               Decimal             @db.Decimal(10, 2)
  category            String
  certificationStatus CertificationStatus @default(PENDING)
  availableQuantity   Int                 @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  vendor VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([category])
  @@index([certificationStatus])
}

model RentalSpace {
  id           String             @id @default(cuid())
  vendorId     String
  location     String
  size         String
  price        Decimal            @db.Decimal(10, 2)
  availability AvailabilityStatus @default(AVAILABLE)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  vendor   VendorProfile   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  bookings RentalBooking[]

  @@index([location])
  @@index([availability])
}

model RentalBooking {
  id            String      @id @default(cuid())
  userId        String
  rentalSpaceId String
  startDate     DateTime
  endDate       DateTime
  status        OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  rentalSpace RentalSpace @relation(fields: [rentalSpaceId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  produceId String
  vendorId  String
  status    OrderStatus @default(PENDING)
  orderDate DateTime    @default(now())
  quantity  Int         @default(1)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  produce Produce       @relation(fields: [produceId], references: [id], onDelete: Cascade)
  vendor  VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([orderDate])
}

model CommunityPost {
  id          String     @id @default(cuid())
  userId      String
  postContent String
  postDate    DateTime   @default(now())
  status      PostStatus @default(PUBLISHED)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postDate])
}

model SustainabilityCert {
  id                String              @id @default(cuid())
  vendorId          String
  certifyingAgency  String
  certificationDate DateTime
  documentUrl       String?
  status            CertificationStatus @default(PENDING)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  vendor VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Plant {
  id              String            @id @default(cuid())
  userId          String
  vendorId        String?
  plantName       String
  species         String
  plantedAt       DateTime          @default(now())
  expectedHarvest DateTime?
  healthStatus    PlantHealthStatus @default(GOOD)
  growthStage     String            @default("Seedling")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor  VendorProfile? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  updates PlantUpdate[]

  @@index([healthStatus])
}

model PlantUpdate {
  id           String            @id @default(cuid())
  plantId      String
  note         String
  healthStatus PlantHealthStatus @default(GOOD)
  createdAt    DateTime          @default(now())

  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}
